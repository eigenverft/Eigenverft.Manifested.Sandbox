    "policy": {
      "ownershipPolicy": {
        "allowAdoptExternal": false,
        "upgradeAdoptedInstall": false,
        "requirePackageOwnership": true
      },
      "compatibility": {
        "checks": [
          {
            "kind": "osVersion",
            "operator": ">=",
            "value": "10.0"
          }
        ]
      }
    },
    "assigned": {
      "install": {
        "kind": "expandArchive",
        "installDirectory": "ps7-runtime/{releaseTrack}/{version}/{artifactDistributionVariant}",
        "expandedRoot": "auto",
