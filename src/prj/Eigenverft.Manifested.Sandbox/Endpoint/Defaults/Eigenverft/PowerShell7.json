  "presenceDiscovery": {
    "files": [
      "pwsh.exe"
    ],
    "directories": [],
    "commands": [
      {
        "name": "pwsh",
        "relativePath": "pwsh.exe",
        "requiredForState": true,
        "exposeCommand": true,
        "stateChecks": [
          {
            "arguments": [
              "-NoLogo",
              "-NoProfile",
              "-Command",
              "$PSVersionTable.PSVersion.ToString()"
            ],
            "outputPattern": "(?m)^(?<value>\\d+\\.\\d+\\.\\d+)\\s*$",
            "expectedValue": "{version}"
          }
        ]
      }
    ],
    "apps": [],
    "metadataFiles": [],
