{
  "package": {
    "applicationRootDirectory": "%LOCALAPPDATA%/Eigenverft.Manifested.Sandbox",
    "preferredTargetInstallDirectory": "{applicationRootDirectory}/Installed",
    "repositorySources": {
      "EigenverftModule": {
        "kind": "moduleLocal",
        "definitionRoot": "Repositories/EigenverftModule"
      }
    },
    "localRepositoryRoot": "{applicationRootDirectory}/PackageRepositories",
    "layout": {
      "packageDepotRelativePath": "{definitionId}/{releaseTrack}/{version}/{flavor}",
      "packageWorkSlotDirectory": "{definitionId}-{slotHash}"
    },
    "acquisitionEnvironment": {
      "stores": {
        "packageFileStagingDirectory": "{applicationRootDirectory}/FileStage",
        "packageInstallStageDirectory": "{applicationRootDirectory}/InstStage"
      },
      "defaults": {
        "allowFallback": true
      },
      "tracking": {
        "packageFileIndexFilePath": "{applicationRootDirectory}/State/package-file-index.json"
      }
    },
    "packageState": {
      "indexFilePath": "{applicationRootDirectory}/State/package-state-index.json"
    },
    "selectionDefaults": {
      "releaseTrack": "stable",
      "strategy": "latestByVersion"
    }
  }
}

