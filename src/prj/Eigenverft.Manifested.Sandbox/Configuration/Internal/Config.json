{
  "package": {
    "preferredTargetInstallDirectory": "%LOCALAPPDATA%/Eigenverft.Manifested.Sandbox/Installed",
    "repositorySources": {
      "EigenverftModule": {
        "kind": "moduleLocal",
        "definitionRoot": "Repositories/EigenverftModule"
      }
    },
    "localRepositoryRoot": "%LOCALAPPDATA%/Eigenverft.Manifested.Sandbox/PackageRepositories",
    "acquisitionEnvironment": {
      "stores": {
        "packageFileStagingDirectory": "%LOCALAPPDATA%/Eigenverft.Manifested.Sandbox/PackageFileStaging",
        "packageInstallStageDirectory": "%LOCALAPPDATA%/Eigenverft.Manifested.Sandbox/PackageInstallStage"
      },
      "defaults": {
        "allowFallback": true,
        "mirrorDownloadedArtifactsToDefaultPackageDepot": true
      },
      "tracking": {
        "packageFileIndexFilePath": "%LOCALAPPDATA%/Eigenverft.Manifested.Sandbox/State/package-file-index.json"
      }
    },
    "packageState": {
      "indexFilePath": "%LOCALAPPDATA%/Eigenverft.Manifested.Sandbox/State/package-state-index.json"
    },
    "selectionDefaults": {
      "releaseTrack": "stable",
      "strategy": "latestByVersion"
    }
  }
}

