{
  "package": {
    "applicationRootDirectory": "%LOCALAPPDATA%/Programs/Evf.Sandbox",
    "preferredTargetInstallDirectory": "{applicationRootDirectory}/Inst",
    "localRepositoryRoot": "{applicationRootDirectory}/PackageRepositories",
    "shimDirectory": "{applicationRootDirectory}/Shims",
    "layout": {
      "packageDepotRelativePath": "{definitionId}/{releaseTrack}/{version}/{artifactDistributionVariant}",
      "packageWorkSlotDirectory": "{definitionId}-{slotHash}"
    },
    "acquisitionEnvironment": {
      "stores": {
        "packageFileStagingDirectory": "{applicationRootDirectory}/FileStage",
        "packageInstallStageDirectory": "{applicationRootDirectory}/InstStage"
      },
      "defaults": {
        "allowFallback": true
      }
    },
    "packageState": {
      "inventoryFilePath": "{applicationRootDirectory}/State/package-inventory.json",
      "operationHistoryFilePath": "{applicationRootDirectory}/State/package-operation-history.json"
    },
    "selectionDefaults": {
      "releaseTrack": "stable",
      "strategy": "latestByVersion"
    }
  }
}
