{
  "$schema": "./eigenverft-module-package-definition-1.2.schema.json",
  "schemaVersion": "1.2",
  "id": "VisualCppRedistributable",
  "display": {
    "default": {
      "name": "Microsoft Visual C++ Redistributable",
      "publisher": "Microsoft",
      "corporation": "Microsoft Corporation",
      "summary": "Machine-wide Visual C++ runtime prerequisite"
    }
  },
  "packageTargets": [
    {
      "id": "VisualCppRedistributable-x64-stable",
      "channel": "stable",
      "platformTarget": "x64",
      "constraints": {
        "os": [
          "windows"
        ],
        "cpu": [
          "x64"
        ]
      },
      "versionSelection": {
        "strategy": "latestByVersion",
        "allowPrerelease": false
      },
      "artifactDefaults": {
        "fileNameTemplate": "vc_redist.x64.exe",
        "artifactSources": [
          {
            "kind": "packageDepot",
            "searchOrder": 100,
            "verification": {
              "mode": "optional"
            }
          },
          {
            "kind": "download",
            "sourceId": "visualCppRedistributableDownload",
            "sourcePath": "vc14/vc_redist.x64.exe",
            "searchOrder": 900,
            "verification": {
              "mode": "required"
            }
          }
        ]
      }
    }
  ],
  "versionCatalog": [
    {
      "version": "14.0",
      "channels": [
        "stable"
      ],
      "artifactsByTarget": {
        "VisualCppRedistributable-x64-stable": {
          "releaseId": "vc-runtime-x64-stable",
          "publisherSignature": {
            "kind": "authenticode",
            "requireValid": true,
            "subjectContains": "Microsoft Corporation"
          }
        }
      }
    }
  ],
  "discovery": {
    "files": [],
    "directories": [],
    "commands": [],
    "apps": [],
    "metadataFiles": [],
    "signatures": [],
    "fileDetails": [],
    "registry": [
      {
        "paths": [
          "HKLM:\\SOFTWARE\\Microsoft\\VisualStudio\\14.0\\VC\\Runtimes\\x64",
          "HKLM:\\SOFTWARE\\Wow6432Node\\Microsoft\\VisualStudio\\14.0\\VC\\Runtimes\\x64"
        ],
        "valueName": "Installed",
        "expectedValue": "1"
      },
      {
        "paths": [
          "HKLM:\\SOFTWARE\\Microsoft\\VisualStudio\\14.0\\VC\\Runtimes\\x64",
          "HKLM:\\SOFTWARE\\Wow6432Node\\Microsoft\\VisualStudio\\14.0\\VC\\Runtimes\\x64"
        ],
        "valueName": "Version",
        "operator": ">=",
        "expectedValue": "14.0"
      }
    ]
  },
  "stateDiscovery": {
    "installed": {
      "enableDetection": false,
      "searchLocations": [],
      "installRootRules": []
    }
  },
  "upstreamSources": {
    "visualCppRedistributableDownload": {
      "kind": "download",
      "baseUri": "https://aka.ms/"
    }
  },
  "packageOperations": {
    "shared": {
      "ownershipPolicy": {
        "allowAdoptExternal": false,
        "upgradeAdoptedInstall": false,
        "requirePackageOwnership": false
      },
      "compatibility": {
        "checks": [
          {
            "kind": "osVersion",
            "operator": ">=",
            "value": "10.0"
          }
        ]
      }
    },
    "assigned": {
      "kind": "runInstaller",
      "targetKind": "machinePrerequisite",
      "installerKind": "burn",
      "uiMode": "quiet",
      "elevation": "required",
      "timeoutSec": 300,
      "logRelativePath": "visual-cpp-redist/{timestamp}.log",
      "commandArguments": [
        "/install",
        "/quiet",
        "/norestart",
        "/log",
        "{logPath}"
      ],
      "successExitCodes": [
        0,
        1638
      ],
      "restartExitCodes": [
        3010
      ],
      "pathRegistration": {
        "mode": "none"
      },
      "installedStateCheck": {
        "use": "discovery",
        "expectedVersion": "{version}",
        "require": {
          "files": false,
          "directories": false,
          "commands": false,
          "apps": false,
          "metadataFiles": false,
          "signatures": false,
          "fileDetails": false,
          "registry": true
        }
      },
      "versionUpdatePolicy": {
        "whenAssigned": "trackSelectedVersion",
        "onSameSelectedVersion": "reuseOrRepair",
        "onNewSelectedVersion": "replacePackageOwnedInstall"
      }
    },
    "removed": {
      "operation": {
        "kind": "none"
      },
      "verifyAbsent": {
        "use": "discovery",
        "require": {
          "files": true,
          "directories": false,
          "commands": true,
          "apps": false,
          "metadataFiles": false,
          "signatures": false,
          "fileDetails": false,
          "registry": false
        }
      },
      "cleanup": {
        "inventory": true,
        "shims": true,
        "path": true,
        "workDirectories": true
      }
    }
  }
}
