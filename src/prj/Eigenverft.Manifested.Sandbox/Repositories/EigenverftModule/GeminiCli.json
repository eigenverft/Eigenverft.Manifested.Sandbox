{
  "schemaVersion": "1.0",
  "id": "GeminiCli",
  "display": {
    "default": {
      "name": "Gemini CLI",
      "publisher": "Google",
      "corporation": "Google",
      "summary": "Pinned Gemini CLI npm runtime"
    },
    "localizations": {}
  },
  "upstreamSources": {},
  "dependencies": [
    {
      "definitionId": "NodeRuntime"
    }
  ],
  "providedTools": {
    "commands": [
      {
        "name": "gemini",
        "relativePath": "gemini.cmd"
      }
    ],
    "apps": []
  },
  "releaseDefaults": {
    "compatibility": {
      "checks": [
        {
          "kind": "osVersion",
          "operator": ">=",
          "value": "10.0"
        }
      ]
    },
    "install": {
      "kind": "npmGlobalPackage",
      "installerCommand": "npm",
      "packageSpec": "@google/gemini-cli@{version}",
      "installDirectory": "gemini-runtime/{releaseTrack}/{version}/{flavor}",
      "pathRegistration": {
        "mode": "user",
        "source": {
          "kind": "commandEntryPoint",
          "value": "gemini"
        }
      }
    },
    "validation": {
      "files": [
        "gemini.cmd",
        "node_modules/@google/gemini-cli/package.json"
      ],
      "directories": [
        "node_modules"
      ],
      "commandChecks": [
        {
          "entryPoint": "gemini",
          "arguments": [
            "--version"
          ],
          "outputPattern": "(?m)^(?<value>.+\\S.*)$"
        }
      ],
      "metadataFiles": [],
      "signatures": [],
      "fileDetails": [],
      "registryChecks": []
    },
    "existingInstallDiscovery": {
      "enableDetection": false,
      "searchLocations": [],
      "installRootRules": []
    },
    "existingInstallPolicy": {
      "allowAdoptExternal": false,
      "upgradeAdoptedInstall": false,
      "requirePackageOwnership": true
    }
  },
  "releases": [
    {
      "id": "gemini-runtime-win32-x64-stable",
      "version": "0.39.1",
      "releaseTrack": "stable",
      "flavor": "win32-x64",
      "constraints": {
        "os": [
          "windows"
        ],
        "cpu": [
          "x64"
        ]
      }
    },
    {
      "id": "gemini-runtime-win32-arm64-stable",
      "version": "0.39.1",
      "releaseTrack": "stable",
      "flavor": "win32-arm64",
      "constraints": {
        "os": [
          "windows"
        ],
        "cpu": [
          "arm64"
        ]
      }
    }
  ]
}
