{
  "schemaVersion": "1.0",
  "id": "OpenCodeCli",
  "display": {
    "default": {
      "name": "OpenCode CLI",
      "publisher": "SST",
      "corporation": "SST",
      "summary": "Pinned OpenCode CLI npm runtime"
    },
    "localizations": {}
  },
  "upstreamSources": {},
  "providedTools": {
    "commands": [
      {
        "name": "opencode",
        "relativePath": "opencode.cmd"
      }
    ],
    "apps": []
  },
  "releaseDefaults": {
    "compatibility": {
      "checks": [
        {
          "kind": "osVersion",
          "operator": ">=",
          "value": "10.0"
        }
      ]
    },
    "install": {
      "kind": "packageManagerInstall",
      "managerKind": "npm",
      "managerDependency": {
        "definitionId": "NodeRuntime",
        "command": "npm"
      },
      "packageSpec": "opencode-ai@{version}",
      "installDirectory": "opencode-runtime/{releaseTrack}/{version}/{flavor}",
      "pathRegistration": {
        "mode": "user",
        "source": {
          "kind": "commandEntryPoint",
          "value": "opencode"
        }
      }
    },
    "validation": {
      "files": [
        "opencode.cmd",
        "node_modules/opencode-ai/package.json"
      ],
      "directories": [
        "node_modules"
      ],
      "commandChecks": [
        {
          "entryPoint": "opencode",
          "arguments": [
            "--version"
          ],
          "outputPattern": "(?m)^(?<value>.+\\S.*)$"
        }
      ],
      "metadataFiles": [],
      "signatures": [],
      "fileDetails": [],
      "registryChecks": []
    },
    "existingInstallDiscovery": {
      "enableDetection": false,
      "searchLocations": [],
      "installRootRules": []
    },
    "existingInstallPolicy": {
      "allowAdoptExternal": false,
      "upgradeAdoptedInstall": false,
      "requirePackageModelOwnership": true
    }
  },
  "releases": [
    {
      "id": "opencode-runtime-win32-x64-stable",
      "version": "1.14.24",
      "releaseTrack": "stable",
      "flavor": "win32-x64",
      "constraints": {
        "os": [
          "windows"
        ],
        "cpu": [
          "x64"
        ]
      }
    },
    {
      "id": "opencode-runtime-win32-arm64-stable",
      "version": "1.14.24",
      "releaseTrack": "stable",
      "flavor": "win32-arm64",
      "constraints": {
        "os": [
          "windows"
        ],
        "cpu": [
          "arm64"
        ]
      }
    }
  ]
}
