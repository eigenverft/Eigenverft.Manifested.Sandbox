{
  "schemaVersion": "1.1",
  "id": "QwenCli",
  "display": {
    "default": {
      "name": "Qwen CLI",
      "publisher": "Alibaba Cloud",
      "corporation": "Alibaba Cloud",
      "summary": "Pinned Qwen CLI npm runtime"
    }
  },
  "upstreamSources": {},
  "dependencies": {
    "repositoryId": "EigenverftModule",
    "definitionId": "NodeRuntime"
  },
  "providedTools": {
    "commands": [
      {
        "name": "qwen",
        "relativePath": "qwen.cmd"
      }
    ],
    "apps": []
  },
  "shared": {
    "ownershipPolicy": {
      "allowAdoptExternal": false,
      "upgradeAdoptedInstall": false,
      "requirePackageOwnership": true
    },
    "compatibility": {
      "checks": [
        {
          "kind": "osVersion",
          "operator": ">=",
          "value": "10.0"
        }
      ]
    },
    "remove": {
      "keepInstallDirectory": false,
      "keepInventoryRecord": false,
      "requireProcessExit": [],
      "keepShims": false
    },
    "discovery": {
      "enableDetection": false,
      "searchLocations": [],
      "installRootRules": []
    },
    "install": {
      "kind": "npmGlobalPackage",
      "installerCommand": "npm",
      "packageSpec": "@qwen-code/qwen-code@{version}",
      "installDirectory": "qwen-cli-runtime/{releaseTrack}/{version}/{flavor}",
      "pathRegistration": {
        "mode": "user",
        "source": {
          "kind": "shim",
          "value": "qwen"
        }
      }
    },
    "validation": {
      "files": [
        "qwen.cmd",
        "node_modules/@qwen-code/qwen-code/package.json"
      ],
      "directories": [
        "node_modules"
      ],
      "commandChecks": [
        {
          "entryPoint": "qwen",
          "arguments": [
            "--version"
          ],
          "outputPattern": "(?m)^(?<value>.+\\S.*)$"
        }
      ],
      "metadataFiles": [],
      "signatures": [],
      "fileDetails": [],
      "registryChecks": []
    }
  },
  "releases": [
    {
      "id": "qwen-cli-runtime-win32-x64-stable",
      "version": "0.15.2",
      "releaseTrack": "stable",
      "flavor": "win32-x64",
      "constraints": {
        "os": [
          "windows"
        ],
        "cpu": [
          "x64"
        ]
      }
    },
    {
      "id": "qwen-cli-runtime-win32-arm64-stable",
      "version": "0.15.2",
      "releaseTrack": "stable",
      "flavor": "win32-arm64",
      "constraints": {
        "os": [
          "windows"
        ],
        "cpu": [
          "arm64"
        ]
      }
    }
  ],
  "$schema": "./eigenverft-module-package-definition-1.1.schema.json"
}