        "autoUpdateSupported": false,
        "integrity": {
          "algorithm": "sha256",
          "sha256": "2a0406b834d4ff33414f70597b67797466ba2344baa534ab8f62c4eae1c3e599"
        }
      },
      "acquisitionCandidates": [
        {
          "kind": "packageDepot",
          "priority": 250,
          "verification": {
